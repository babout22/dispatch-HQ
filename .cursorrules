```javascript
// ALL fetches via _fetchWithTimeout (never raw fetch):
SyncService._fetchWithTimeout(url, options, timeoutMs)
// Timeouts: ping=15000, POST=30000, pull=60000

// ALL POST bodies use text/plain (avoids CORS preflight on GAS):
headers: { "Content-Type": "text/plain;charset=utf-8" }

// ALWAYS check resp.ok after fetch
